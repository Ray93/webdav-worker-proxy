{
  "name": "webdav-worker-proxy-test",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-04-16",
  "env": {
    "with_secret": {
      "kv_namespaces": [
        {
          "binding": "APP_KV",
          "id": "test-kv-id"
        }
      ],
      "vars": {
        "ADMIN_SESSION_SECRET": "test-admin-session-secret"
      }
    }
  },
  "kv_namespaces": [
    {
      "binding": "APP_KV",
      "id": "test-kv-id"
    }
  ]
}
