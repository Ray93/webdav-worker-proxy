{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals", "@cloudflare/workers-types"],
    "allowImportingTsExtensions": true,
    "baseUrl": "."
  },
  "include": ["src", "tests", "vite.config.ts", "vitest.config.ts"]
}
